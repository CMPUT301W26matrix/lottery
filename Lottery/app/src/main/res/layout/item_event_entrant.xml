<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/divider_gray"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title Row with Status Badge -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvEventTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/tvEventStatus"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/event_title"
                android:textColor="@color/primary_blue"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEventStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_status_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="@string/wait_listed"
                android:textColor="@color/primary_blue"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" /> <!-- Hidden by default, shown when needed -->
        </RelativeLayout>

        <!-- Event Date -->
        <TextView
            android:id="@+id/tvEventDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/mm_dd_yyyy_hh_mm"
            android:textColor="@color/text_gray"
            android:textSize="14sp" />

        <!-- Registration Period (if available) -->
        <TextView
            android:id="@+id/tvRegistrationPeriod"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/registration_period_template"
            android:textColor="@color/text_gray"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- People in Waitlist Count -->
        <TextView
            android:id="@+id/tvWaitlistCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/people_in_waitlist_template"
            android:textColor="@color/text_gray"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Event Description Preview -->
        <TextView
            android:id="@+id/tvEventDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="3"
            android:ellipsize="end"
            android:text="@string/event_description_placeholder"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/divider_gray" />

        <!-- View Details Button (Always visible) -->
        <Button
            android:id="@+id/btnViewDetails"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/primary_blue"
            android:text="@string/view_details"
            android:textColor="@color/white"
            app:cornerRadius="24dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>