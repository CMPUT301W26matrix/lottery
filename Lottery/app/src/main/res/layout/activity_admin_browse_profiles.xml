<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    tools:context=".AdminBrowseProfilesActivity">

    <LinearLayout
        android:id="@+id/profiles_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="32dp"
        android:paddingEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvBrowseProfilesTitle"
            android:layout_height="wrap_content"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="@string/browse_profiles"
            android:textColor="@color/primary_blue"
            android:textSize="28sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnEnableDeleteProfile"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:backgroundTint="@color/primary_blue"
            android:minHeight="40dp"
            android:paddingHorizontal="16dp"
            android:text="Enable Deletion"
            android:textAllCaps="false" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvEmptyProfiles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:padding="16dp"
        android:text="@string/there_are_no_user_profiles_in_the_system"
        android:textColor="@color/text_gray"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/profiles_header"
        tools:visibility="gone" />

    <ListView
        android:id="@+id/lvProfiles"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/profiles_header"
        tools:listitem="@android:layout/simple_list_item_2" />

    <FrameLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <include layout="@layout/layout_bottom_nav_admin" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
